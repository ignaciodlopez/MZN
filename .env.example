# Ruta base de la aplicación. Usar "/" para dominio raíz (Cloudflare Pages).
VITE_BASE_PATH=/

# Endpoint externo para el formulario de contacto (Web3Forms, Formspree, Worker, etc.).
# Si queda vacío, el sitio muestra un enlace de correo alternativo.
VITE_CONTACT_ENDPOINT=

# Access key pública del servicio de formularios (por ejemplo, Web3Forms).
# ATENCIÓN: todo valor VITE_* es visible en el navegador. Nunca poner secretos privados.
VITE_CONTACT_ACCESS_KEY=

# URL pública del sitio (canonical, Open Graph, sitemap).
VITE_SITE_URL=https://example.pages.dev

# Activar cursor personalizado en escritorio.
VITE_ENABLE_CUSTOM_CURSOR=true

# Activar loader inicial (se muestra una vez por sesión).
VITE_ENABLE_PAGE_LOADER=true
